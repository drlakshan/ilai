---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Layout
	title="ILAI Academy | AI, medicine, learning, and professional judgement"
	description="ILAI Academy is the public platform of Dr. MTD Lakshan — exploring how AI can be used with clarity, responsibility, and professional judgement in medicine, education, and institutional life."
>
	<SiteHeader currentPath="/" />

	<main>
		<section class="hero container">
			<div class="hero-copy">
				<p class="eyebrow">AI, medicine, learning, and professional judgement</p>
				<h1>Thoughtful work on AI in medicine, education, and institutional practice.</h1>
				<p class="lead">
					ILAI Academy is the public platform of Dr. MTD Lakshan, exploring how AI can be used with
					clarity, responsibility, and professional judgement. Through writing, lectures, workshops,
					and institutional engagement, the work here focuses on careful adoption rather than hype.
				</p>
				<div class="actions">
					<a class="button primary" href="/writing">Explore the Writing</a>
					<a class="button secondary" href="/journey">View the Journey</a>
					<a class="button secondary" href="/contact">Contact</a>
				</div>
			</div>

			<div class="card profile-card">
				<img src="/images/profile/dr-mtd-lakshan-2024.jpeg" alt="Dr. MTD Lakshan" class="profile-image" />
				<p class="profile-caption">Dr. MTD Lakshan — Consultant ENT &amp; Head and Neck Surgeon, medical educator, and founder of ILAI Academy.</p>
				<ul class="profile-signals">
					<li>Public writing on AI, medicine, education, and professional judgement</li>
					<li>Invited talks, workshops, and institutional engagement</li>
					<li>Practical work shaped by clinical and educational realities</li>
				</ul>
			</div>
		</section>

		<section class="container section">
			<div class="section-head">
				<p class="kicker">At a glance</p>
				<h2 class="section-title">A simpler way to understand what this site is for</h2>
			</div>
			<div class="grid three-up">
				<article class="card panel">
					<p class="card-kicker">Who is this for?</p>
					<h3>Clinicians, educators, and healthcare leaders.</h3>
					<p>
						This site is for people who want to use AI thoughtfully in professional life, especially in
						medicine, education, and institutions.
					</p>
				</article>
				<article class="card panel">
					<p class="card-kicker">What kind of work happens here?</p>
					<h3>Writing, talks, workshops, and practical institutional work.</h3>
					<p>
						The focus is not technology for its own sake, but how AI can be used well in real clinical,
						educational, and organisational settings.
					</p>
				</article>
				<article class="card panel">
					<p class="card-kicker">Why trust this?</p>
					<h3>Because the work is grounded in real practice.</h3>
					<p>
						It is led by a practising surgeon and medical educator doing public, documented work in AI,
						teaching, speaking, and institutional adoption.
					</p>
				</article>
			</div>
		</section>

		<section class="container section">
			<div class="section-head">
				<p class="kicker">Start here</p>
				<h2 class="section-title">Choose the next page based on what you need</h2>
			</div>
			<div class="grid three-up">
				<a class="card panel action-card" href="/writing">
					<p class="card-kicker">Writing</p>
					<h3>Read the ideas in public.</h3>
					<p>Start with essays, Substack posts, and other published work.</p>
					<span class="text-link">Explore the writing →</span>
				</a>
				<a class="card panel action-card" href="/journey">
					<p class="card-kicker">Journey</p>
					<h3>See the documented pathway.</h3>
					<p>Follow the learning, talks, experiments, and public milestones over time.</p>
					<span class="text-link">View the journey →</span>
				</a>
				<a class="card panel action-card" href="/contact">
					<p class="card-kicker">Contact</p>
					<h3>Start a professional conversation.</h3>
					<p>Use this if you are exploring a talk, workshop, collaboration, or enquiry.</p>
					<span class="text-link">Open contact options →</span>
				</a>
			</div>
		</section>
	</main>

	<SiteFooter />
</Layout>

<style>
	.hero {
		display: grid;
		grid-template-columns: 1.15fr 0.85fr;
		gap: 2rem;
		padding: 5rem 0 2rem;
		align-items: center;
	}

	.eyebrow,
	.kicker,
	.card-kicker {
		text-transform: uppercase;
		letter-spacing: 0.14em;
		font-size: 0.76rem;
		font-weight: 800;
		color: var(--brand-2);
	}

	h1 {
		font-size: clamp(2.8rem, 6vw, 5rem);
		line-height: 0.98;
		letter-spacing: -0.05em;
		margin: 0.5rem 0 1rem;
		max-width: 12ch;
	}

	.lead {
		font-size: 1.08rem;
		line-height: 1.9;
		color: var(--muted);
		max-width: 62ch;
	}

	.actions {
		display: flex;
		gap: 0.9rem;
		margin-top: 1.5rem;
		flex-wrap: wrap;
	}

	.section {
		padding: 1.5rem 0 2rem;
	}

	.section-head {
		max-width: 56rem;
		margin-bottom: 1.25rem;
	}

	.profile-card,
	.panel {
		padding: 1.5rem;
	}

	.profile-card {
		background: linear-gradient(180deg, rgba(255, 253, 249, 0.92), rgba(247, 242, 235, 0.82));
	}

	.profile-image {
		display: block;
		width: 100%;
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: center top;
		border-radius: 18px;
	}

	.profile-caption {
		margin: 1rem 0 0;
		font-size: 0.98rem;
		font-weight: 600;
		line-height: 1.7;
	}

	.profile-signals {
		margin: 1rem 0 0;
		padding-left: 1.15rem;
		color: var(--muted);
		line-height: 1.8;
	}

	.grid {
		display: grid;
		gap: 1rem;
	}

	.three-up {
		grid-template-columns: repeat(3, 1fr);
	}

	.panel h3 {
		margin: 0.35rem 0 0.7rem;
		font-size: 1.15rem;
		line-height: 1.35;
	}

	.panel p,
	.panel li {
		color: var(--muted);
		line-height: 1.8;
	}

	.section-title {
		font-size: clamp(1.8rem, 2.4vw, 2.5rem);
		line-height: 1.15;
		margin: 0.35rem 0 0;
	}

	.action-card {
		display: block;
		transition: 180ms ease;
	}

	.action-card:hover {
		transform: translateY(-2px);
	}

	.text-link {
		display: inline-block;
		margin-top: 0.4rem;
		font-weight: 700;
		color: var(--brand);
	}

	@media (max-width: 900px) {
		.hero,
		.three-up {
			grid-template-columns: 1fr;
		}

		h1 {
			max-width: unset;
		}
	}
</style>

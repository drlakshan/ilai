---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { featuredWriting, writingPlatforms } from '../data/writing';
---

<Layout title="Writing | ILAI Academy" description="Public writing by Dr. MTD Lakshan across Substack, LinkedIn, SSRN, and essays on AI, learning, medicine, and professional judgement.">
	<SiteHeader currentPath="/writing" />

	<main class="container page">
		<section class="hero">
			<p class="kicker">Writing</p>
			<h1>Writing in public as a way of thinking in public.</h1>
			<p class="lead">
				This page gathers the main writing channels and selected pieces connected to ILAI Academy. The aim is
				not content volume for its own sake, but durable thinking about AI, medicine, education, knowledge
				work, and responsible professional judgement.
			</p>
		</section>

		<section class="grid two-up section">
			{
				writingPlatforms.map((platform) => (
					<article class="card panel platform-card">
						<p class="kicker">Platform</p>
						<h2>{platform.title}</h2>
						<p>{platform.description}</p>
						<a class="button primary" href={platform.url} target="_blank" rel="noreferrer">{platform.cta}</a>
					</article>
				))
			}
		</section>

		<section class="section">
			<div class="section-head">
				<p class="kicker">Selected writing</p>
				<h2>Representative pieces and public intellectual signals</h2>
			</div>
			<div class="grid feature-grid">
				{
					featuredWriting.map((item) => (
						<article class="card panel article-card">
							<div class="meta">
								<span class="tag">{item.type}</span>
								<span class="publication">{item.publication}</span>
							</div>
							<h3>{item.title}</h3>
							<p>{item.description}</p>
							<a class="text-link" href={item.url} target="_blank" rel="noreferrer">Open piece →</a>
						</article>
					))
				}
			</div>
		</section>

		<section class="grid split section">
			<article class="card panel">
				<p class="kicker">What the writing is about</p>
				<ul>
					<li>AI in medicine and medical education</li>
					<li>Learning science, cognition, and knowledge work</li>
					<li>Responsible AI use, governance, and professional judgement</li>
					<li>How clinicians and educators should think in an AI-rich era</li>
				</ul>
			</article>
			<article class="card panel">
				<p class="kicker">How to use this page</p>
				<p>
					If you want the most current stream, start with Substack. If you want shorter updates and professional
					context, use LinkedIn. If you want stronger formal signals, the SSRN and essay links offer a better
					sense of the underlying thinking.
				</p>
			</article>
		</section>

		<section class="card panel section closing">
			<p class="kicker">Next step</p>
			<h2>If the writing resonates, that is probably the best starting point for a conversation.</h2>
			<p>
				The writing is not separate from the talks, workshops, and collaborations. It is often where the ideas
				first become clear enough to be useful.
			</p>
			<div class="actions">
				<a class="button primary" href="https://drlakshan.substack.com/" target="_blank" rel="noreferrer">Read on Substack</a>
				<a class="button secondary" href="/contact">Open contact options</a>
			</div>
		</section>
	</main>

	<SiteFooter />
</Layout>

<style>
	.page { padding: 3.5rem 0 2rem; }
	.section { margin-top: 1.5rem; }
	.hero { max-width: 920px; }
	.kicker { color: var(--brand-2); font-weight: 800; text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.78rem; }
	h1 { font-size: clamp(2.4rem, 5vw, 4.4rem); line-height: 1.02; letter-spacing: -0.05em; margin: 0.5rem 0 1rem; }
	h2, h3 { margin-top: 0; }
	.lead, p, li { color: var(--muted); line-height: 1.85; }
	.grid { display: grid; gap: 1rem; }
	.two-up { grid-template-columns: repeat(2, 1fr); }
	.split { grid-template-columns: 1fr 1fr; }
	.feature-grid { grid-template-columns: repeat(3, 1fr); }
	.panel { padding: 1.5rem; }
	.meta { display: flex; gap: 0.6rem; align-items: center; flex-wrap: wrap; margin-bottom: 0.7rem; }
	.tag,
	.publication {
		display: inline-flex;
		padding: 0.25rem 0.55rem;
		border-radius: 999px;
		font-size: 0.82rem;
		font-weight: 700;
	}
	.tag { background: rgba(31, 58, 95, 0.08); color: var(--brand); }
	.publication { background: rgba(154, 123, 79, 0.12); color: var(--brand-2); }
	.text-link { display: inline-block; margin-top: 0.5rem; color: var(--brand); font-weight: 700; }
	.actions { display: flex; gap: 0.9rem; margin-top: 1rem; flex-wrap: wrap; }
	ul { margin: 0; padding-left: 1.2rem; }
	@media (max-width: 900px) {
		.two-up,
		.split,
		.feature-grid { grid-template-columns: 1fr; }
	}
</style>

---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'ILAI Academy | AI for Medical Education and Clinical Practice',
	description = 'ILAI Academy helps clinicians, educators, and healthcare leaders use AI safely, thoughtfully, and effectively.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--bg: #f3f0ea;
		--surface: rgba(255, 252, 247, 0.72);
		--surface-strong: #fffdf9;
		--text: #171411;
		--muted: #6d655d;
		--line: rgba(23, 20, 17, 0.1);
		--brand: #1f3a5f;
		--brand-2: #9a7b4f;
		--accent: #6f8f7b;
		--shadow: 0 24px 70px rgba(49, 39, 28, 0.09);
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		background:
			radial-gradient(circle at top left, rgba(154, 123, 79, 0.12), transparent 26%),
			radial-gradient(circle at top right, rgba(31, 58, 95, 0.08), transparent 24%),
			linear-gradient(180deg, #fbf8f3 0%, var(--bg) 100%);
		color: var(--text);
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	* {
		box-sizing: border-box;
	}

	.container {
		width: min(1120px, calc(100% - 2rem));
		margin: 0 auto;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 0.9rem 1.2rem;
		border-radius: 999px;
		font-weight: 700;
		transition: 180ms ease;
	}

	.button.primary {
		background: linear-gradient(135deg, var(--brand), #2b507e);
		color: white;
		box-shadow: 0 14px 34px rgba(31, 58, 95, 0.22);
	}

	.button.secondary {
		background: transparent;
		border: 1px solid var(--line);
	}

	.button:hover {
		transform: translateY(-1px);
	}

	.section-title {
		font-size: clamp(1.8rem, 2vw, 2.6rem);
		line-height: 1.15;
		margin: 0 0 0.75rem;
	}

	.section-copy {
		font-size: 1.05rem;
		line-height: 1.75;
		color: var(--muted);
		max-width: 64ch;
	}

	.card {
		background: var(--surface);
		backdrop-filter: blur(16px);
		border: 1px solid rgba(255, 255, 255, 0.65);
		box-shadow: var(--shadow);
		border-radius: 28px;
	}
</style>
